# Example .env for xo-apply — copy to `.env` and fill in real values.
#
# ============================================================================
# WHAT THIS FILE IS
# ============================================================================
# This file holds SECRET VALUES ONLY (passwords + your API token). It is a
# separate thing from your config file (xo-config.yaml):
#
#   xo-config.yaml  = your XO setup (users, servers, remotes, jobs).
#                     `export` writes it. `apply` reads it.
#   .env (this file)= just the secret values those placeholders point at.
#                     YOU write it. `apply` reads it.
#
# `export` NEVER reads or writes this file. These variables are used when you
# IMPORT — i.e. `apply` (the connection lines below are the one exception:
# XO_URL/XO_TOKEN are needed by every command, including export).
#
# In the config file you reference a value from here with `${env:NAME}`, e.g.
#   password: ${env:SMB_BACKUP_PASSWORD}
# and apply looks up NAME in this file. A real shell env var always wins over
# this file. `.env` is git-ignored — never commit real secrets.
# ============================================================================


# --- Connection (used by EVERY command, including export) -------------------
# The XO you are targeting, and a token created in that XO
# (Settings → API tokens, or POST /rest/v0/users/me/authentication_tokens).
# You can also pass these as --url / --token instead of putting them here.
XO_URL=https://xo.example.lan
XO_TOKEN=your-token-here


# --- Backup-repository secrets (SMB / S3 remotes) — used by apply ------------
# Only needed if your config file has `password: ${env:...}` on a remote.
# `export` picks the NAME and prints it in a warning; match those names here.
SMB_BACKUP_PASSWORD=change-me
S3_BACKUP_SECRET_KEY=change-me


# --- Server (pool connection) passwords — used by apply ----------------------
# Required to CREATE a pool connection. `export` always writes servers with a
# `${env:...}` reference and names the variable per host:
#   XO_SERVER_<HOST>_PASSWORD   (dots/dashes -> underscores, uppercased)
# Set one line per pool, matching your actual addresses.
# (Not needed for `diff`, or for a pool that already exists in the target XO.)
XO_SERVER_10_100_2_10_PASSWORD=change-me
XO_SERVER_10_100_2_156_PASSWORD=change-me


# --- User passwords — used by apply -----------------------------------------
# One line per user. The NAME is XO_USER_<EMAIL>_PASSWORD, with every non-letter
# in the email turned into "_" and uppercased (e.g. ops@example.com ->
# XO_USER_OPS_EXAMPLE_COM_PASSWORD). In xo-config.yaml the user's password line
# must reference the same NAME:  password: ${env:XO_USER_OPS_EXAMPLE_COM_PASSWORD}
XO_USER_OPS_EXAMPLE_COM_PASSWORD=change-me
XO_USER_ADMIN_EXAMPLE_COM_PASSWORD=change-me
